# GCP service account key (stored outside repo, never committed)
# Create a service account with Vertex AI User role, download the JSON key,
# and place it somewhere safe outside this repo.
GOOGLE_APPLICATION_CREDENTIALS=$HOME/.gcp/your-service-account-key.json

# GCP project configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Gemini model
GEMINI_MODEL=gemini-3.1-pro-preview

# CORS: comma-separated list of allowed origins. The default in app/config.py
# already covers the deployed Firebase Hosting URLs and localhost:5173, so you
# normally only need to set this if you're testing from a different origin.
# ALLOWED_ORIGINS=https://synthetic-student-gen.web.app,https://synthetic-student-gen.firebaseapp.com,http://localhost:5173

# Interactive docs (/docs, /redoc, /openapi.json). Disabled by default so prod
# stays locked down. Set to true for local development.
# DOCS_ENABLED=true
