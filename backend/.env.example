# GCP service account key (stored outside repo, never committed)
# Create a service account with Vertex AI User role, download the JSON key,
# and place it somewhere safe outside this repo.
GOOGLE_APPLICATION_CREDENTIALS=$HOME/.gcp/your-service-account-key.json

# GCP project configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Gemini model
GEMINI_MODEL=gemini-2.5-flash

# Frontend origin for CORS (local dev)
FRONTEND_ORIGIN=http://localhost:5173
